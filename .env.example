# Do not commit .env — copy from this file: cp .env.example .env
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Yandex IMAP defaults
YANDEX_IMAP_HOST=imap.yandex.com.tr
YANDEX_IMAP_PORT=993
YANDEX_IMAP_SSL=true

# cPanel IMAP defaults
CPANEL_IMAP_PORT=993
CPANEL_IMAP_SSL=true

# Worker parallelism (number of concurrent imapsync jobs)
WORKER_CONCURRENCY=2

# Redis
REDIS_URL=redis://redis:6379/0

# Database
DATABASE_URL=sqlite:////data/email_transfer.db

# Logs directory
LOGS_DIR=/logs

# Admin login (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_EXPIRE_HOURS=24
